{
  "rust": {
    "extensions": [".rs", ".toml", ".lock"],
    "dirs": ["crates/", "src/"],
    "forbidden": ["package.json", "mix.exs"]
  },
  "elixir": {
    "extensions": [".ex", ".exs", ".heex", ".lock"],
    "dirs": ["lib/", "test/", "priv/repo/"],
    "forbidden": ["Cargo.toml"]
  },
  "frontend_ts": {
    "extensions": [".ts", ".tsx", ".js", ".json", ".css"],
    "dirs": ["src/web/", "public/"],
    "forbidden": ["Cargo.toml", "mix.exs"]
  },
  "python_ai": {
    "extensions": [".py", ".ipynb", ".txt"],
    "dirs": ["ai_service/", "scripts/"],
    "forbidden": ["src/web/"]
  }
}
