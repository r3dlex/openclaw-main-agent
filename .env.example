# Path to the Openclaw agents workspace directory
OPENCLAW_AGENTS_WORKSPACE_DIR=/path/to/your/openclaw/workspace

# IAMQ message queue base URL
IAMQ_BASE_URL=http://127.0.0.1:18790

# This agent's ID in the IAMQ registry
AGENT_ID=main

# User-facing notifications are handled by the OpenClaw gateway.
# Telegram bot tokens are configured in ~/.openclaw/openclaw.json (channels.telegram.accounts).
